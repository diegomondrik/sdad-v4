# MCP config — contains tokens, never commit
mcp.json

# SDAD runtime state (hook artifacts: compact anchor snapshot, autocommit hold sentinel)
# .sdad/eval/ is the exception: the methodology golden dataset is versioned (v5 I3)
.sdad/*
!.sdad/eval/
!.sdad/lib/
# Pyplan model snapshots are versioned: the .ppl backup of the model after each
# Build-via-AI increment (Pyplan projects only). See SPEC SDAD v5.2 versioning patch.
!.sdad/pyplan-snapshots/
# ...but the last green-run stamp is machine state, not part of the dataset
.sdad/eval/last-run
# agent delegation output is runtime state, never versioned
.sdad/agent_output.tmp

